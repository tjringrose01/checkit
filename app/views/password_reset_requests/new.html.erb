<section>
  <h1>Forgot Password</h1>
  <p>Enter your user ID and email address to receive a verification code.</p>

  <%= form_with scope: :password_reset_request, url: password_reset_request_path, method: :post do |form| %>
    <div>
      <%= form.label :user_id, "Username" %>
      <%= form.text_field :user_id, required: true, autocomplete: "username" %>
    </div>

    <div>
      <%= form.label :email %>
      <%= form.email_field :email, required: true, autocomplete: "email" %>
    </div>

    <%= form.submit "Send verification code", class: "primary-button" %>
  <% end %>

  <p style="margin-top: 16px;">
    <%= link_to "Back to sign in", new_session_path %>
  </p>
</section>
