<section class="page-header">
  <div>
    <p class="eyebrow">Admin Workspace</p>
    <h1>Manage Checkit</h1>
    <p>Choose between administrative access controls and checklist-focused management.</p>
  </div>

  <div class="admin-actions">
    <%= link_to "Back To User View", root_path, class: "secondary-link" %>
  </div>
</section>

<section class="checklists">
  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Administration</p>
        <h2>User Administration</h2>
      </div>

      <%= link_to admin_users_path, class: "primary-link" do %>
        <span class="user-menu__icon"><%= menu_icon(:admin) %></span>
        <span>Open User Administration</span>
      <% end %>
    </header>

    <p>Manage user access, role assignments, password resets, unlock actions, and account lifecycle controls.</p>

    <% if @locked_users.any? %>
      <ul class="checklist-items">
        <% @locked_users.each do |user| %>
          <li class="checklist-item">
            <div class="checklist-item__content">
              <h3><%= user.user_id %></h3>
              <p><%= user.email %></p>
              <p>Failed attempts: <%= user.failed_login_attempts %></p>
            </div>

            <%= button_to "Unlock User", unlock_admin_user_path(user), method: :patch, class: "primary-button" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No locked users.</p>
    <% end %>
  </article>

  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Checklist Management</p>
        <h2>Checklist Workspace</h2>
      </div>

      <div class="admin-actions">
        <%= link_to admin_checklists_path, class: "secondary-link" do %>
          <span class="user-menu__icon"><%= menu_icon(:checklist_management) %></span>
          <span>Open Checklist Manager</span>
        <% end %>
        <%= link_to "New Checklist", new_admin_checklist_path, class: "primary-link" %>
      </div>
    </header>

    <p>Create, edit, import, and maintain checklist content from the checklist management workspace.</p>

    <% if @checklists.any? %>
      <ul class="checklist-items">
        <% @checklists.each do |checklist| %>
          <li class="checklist-item">
            <div class="checklist-item__content">
              <h3><%= checklist.title %></h3>
              <p>Status: <%= checklist.status.titleize %></p>
              <p><%= pluralize(checklist.checklist_items.count, "item") %></p>
            </div>

            <%= link_to "Open Checklist", admin_checklist_path(checklist), class: "secondary-link" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No checklists yet.</p>
    <% end %>
  </article>
</section>
