<section class="page-header">
  <div>
    <p class="eyebrow">Admin Workspace</p>
    <h1><%= [@user.first_name, @user.last_name].compact_blank.join(" ").presence || @user.user_id %></h1>
    <p>Manage access state, reset the password, and remove this user when appropriate.</p>
  </div>

  <div class="admin-actions">
    <%= link_to "Back To Users", admin_users_path, class: "secondary-link" %>
    <%= link_to "Back To Checklists", admin_root_path, class: "secondary-link" %>
  </div>
</section>

<section class="checklists">
  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">User Details</p>
        <h2><%= @user.email %></h2>
      </div>
    </header>

    <p>First name: <strong><%= @user.first_name.presence || "Not set" %></strong></p>
    <p>Last name: <strong><%= @user.last_name.presence || "Not set" %></strong></p>
    <p>Username: <strong><%= @user.user_id %></strong></p>
    <p>Role: <strong><%= @user.role %></strong></p>
    <p>Status: <strong><%= @user.enabled? ? "Enabled" : "Disabled" %></strong></p>
    <p>Locked: <strong><%= @user.locked? ? "Yes" : "No" %></strong></p>
    <p>Failed login attempts: <strong><%= @user.failed_login_attempts %></strong></p>
    <p>Must change password: <strong><%= @user.must_change_password? ? "Yes" : "No" %></strong></p>
  </article>

  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Profile</p>
        <h2>Edit User Details</h2>
      </div>
    </header>

    <%= form_with url: update_profile_admin_user_path(@user), method: :patch do |form| %>
      <div>
        <%= form.label :first_name, "First name" %>
        <%= form.text_field :first_name, name: "user[first_name]", value: @user.first_name, autocomplete: "given-name" %>
      </div>

      <div>
        <%= form.label :last_name, "Last name" %>
        <%= form.text_field :last_name, name: "user[last_name]", value: @user.last_name, autocomplete: "family-name" %>
      </div>

      <div>
        <%= form.label :user_id, "Username" %>
        <%= form.text_field :user_id, name: "user[user_id]", value: @user.user_id, required: true, autocomplete: "username" %>
      </div>

      <div>
        <%= form.label :email %>
        <%= form.email_field :email, name: "user[email]", value: @user.email, required: true, autocomplete: "email" %>
      </div>

      <div style="margin-top: 16px;">
        <%= form.submit "Update Profile", class: "primary-button" %>
      </div>
    <% end %>
  </article>

  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Role Assignment</p>
        <h2>Manage Role</h2>
      </div>
    </header>

    <% if @user.admin? %>
      <p>Admin accounts retain the <strong>admin</strong> role and cannot be reassigned through the management interface.</p>
    <% else %>
      <%= form_with url: update_role_admin_user_path(@user), method: :patch do |form| %>
        <div class="form-grid">
          <div>
            <%= form.label :role, "Role" %>
            <%= form.select :role, User.roles.keys.map { |role| [role.titleize, role] }, { selected: @user.role }, { name: "user[role]" } %>
          </div>
        </div>

        <div style="margin-top: 16px;">
          <%= form.submit "Update Role", class: "primary-button" %>
        </div>
      <% end %>
    <% end %>
  </article>

  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Access Control</p>
        <h2>Manage Access</h2>
      </div>
    </header>

    <div class="admin-actions">
      <% unless @user.admin? %>
        <% if @user.enabled? %>
          <%= button_to "Disable User", disable_admin_user_path(@user), method: :patch, class: "secondary-button" %>
        <% else %>
          <%= button_to "Enable User", enable_admin_user_path(@user), method: :patch, class: "primary-button" %>
        <% end %>
      <% end %>

      <% if @user.locked? %>
        <%= button_to "Unlock User", unlock_admin_user_path(@user), method: :patch, class: "primary-button" %>
      <% end %>

      <% unless @user.admin? %>
        <%= button_to "Delete User", admin_user_path(@user), method: :delete, class: "secondary-button" %>
      <% end %>
    </div>
  </article>

  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Password Administration</p>
        <h2>Reset Password</h2>
      </div>
    </header>

    <%= form_with url: reset_password_admin_user_path(@user), method: :patch do |form| %>
      <div class="form-grid">
        <div>
          <%= form.label :password, "New password" %>
          <%= form.password_field :password, name: "user[password]", required: true, minlength: 12, autocomplete: "new-password" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm password" %>
          <%= form.password_field :password_confirmation, name: "user[password_confirmation]", required: true, minlength: 12, autocomplete: "new-password" %>
        </div>
      </div>

      <div style="margin-top: 16px;">
        <%= form.submit "Reset Password", class: "primary-button" %>
      </div>
    <% end %>
  </article>
</section>
