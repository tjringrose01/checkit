<section class="page-header">
  <div>
    <p class="eyebrow">Admin Workspace</p>
    <h1>Checklist Catalog</h1>
    <p>Start with a checklist, then open it to manage its items and CSV imports.</p>
  </div>

  <div class="admin-actions">
    <%= link_to "Back To User View", root_path, class: "secondary-link" %>
    <%= link_to "Manage Users", admin_users_path, class: "secondary-link" %>
    <%= link_to "New Checklist", new_admin_checklist_path, class: "primary-link" %>
  </div>
</section>

<section class="checklists">
  <article class="checklist-card">
    <header class="checklist-card__header">
      <div>
        <p class="eyebrow">Locked Accounts</p>
        <h2>User Access</h2>
      </div>
    </header>

    <% if @locked_users.any? %>
      <ul class="checklist-items">
        <% @locked_users.each do |user| %>
          <li class="checklist-item">
            <div class="checklist-item__content">
              <h3><%= user.user_id %></h3>
              <p><%= user.email %></p>
              <p>Failed attempts: <%= user.failed_login_attempts %></p>
            </div>

            <%= button_to "Unlock User", unlock_admin_user_path(user), method: :patch, class: "primary-button" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No locked users.</p>
    <% end %>
  </article>

  <% @checklists.each do |checklist| %>
    <article class="checklist-card">
      <header class="checklist-card__header">
        <div>
          <p class="eyebrow"><%= checklist.status.titleize %></p>
          <h2><%= checklist.title %></h2>
        </div>

        <p><%= pluralize(checklist.checklist_items.count, "item") %></p>
      </header>

      <% if checklist.notes.present? %>
        <p><%= checklist.notes %></p>
      <% end %>

      <div class="admin-actions">
        <%= link_to "Open Checklist", admin_checklist_path(checklist), class: "primary-link" %>
        <%= button_to "Delete", admin_checklist_path(checklist), method: :delete, class: "secondary-button" %>
      </div>
    </article>
  <% end %>
</section>
