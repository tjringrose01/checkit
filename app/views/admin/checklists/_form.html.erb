<%= form_with model: [ :admin, checklist ] do |form| %>
  <% if checklist.errors.any? %>
    <div class="flash">
      <%= checklist.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="form-grid">
    <div>
      <%= form.label :title %>
      <%= form.text_field :title, required: true %>
    </div>

    <div>
      <%= form.label :status %>
      <%= form.select :status, Checklist.statuses.keys.map { |status| [status.titleize, status] }, required: true %>
    </div>

    <div class="form-grid__full">
      <%= form.label :notes %>
      <%= form.text_area :notes, rows: 5 %>
    </div>
  </div>

  <div class="admin-actions">
    <%= form.submit class: "primary-button" %>
    <%= link_to "Cancel", admin_checklists_path, class: "secondary-link" %>
  </div>
<% end %>
