<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Checkit</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f0e8;
        --surface: #fffaf1;
        --surface-strong: #f0e6d6;
        --text: #1f1a17;
        --muted: #665e58;
        --line: #d8c9b3;
        --accent: #185c52;
        --accent-strong: #103f39;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        background:
          radial-gradient(circle at top, rgba(24, 92, 82, 0.08), transparent 28%),
          linear-gradient(180deg, #f9f5ee 0%, var(--bg) 100%);
        color: var(--text);
      }

      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 24px 16px 48px;
      }

      p, h1, h2, h3, ul, dl {
        margin-top: 0;
      }

      .flash {
        margin-bottom: 16px;
        padding: 12px 14px;
        border: 1px solid var(--line);
        background: var(--surface);
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 24px;
      }

      .eyebrow {
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.75rem;
        color: var(--muted);
      }

      .checklists {
        display: grid;
        gap: 18px;
      }

      .checklist-card,
      .empty-state {
        padding: 20px;
        border: 1px solid var(--line);
        background: var(--surface);
        box-shadow: 0 14px 30px rgba(31, 26, 23, 0.06);
      }

      .checklist-card__header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 18px;
      }

      .checklist-card__notes {
        max-width: 320px;
        color: var(--muted);
      }

      .checklist-items {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 12px;
      }

      .checklist-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        padding: 16px;
        border: 1px solid var(--line);
        background: #fff;
      }

      .checklist-item--complete {
        background: #f1f8f5;
      }

      .checklist-item__text > :last-child {
        margin-bottom: 0;
      }

      .checklist-item__meta {
        margin-top: 12px;
      }

      .checklist-item__meta p:last-child {
        margin-bottom: 0;
      }

      .checklist-item dl {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
        margin-top: 12px;
        margin-bottom: 0;
      }

      .checklist-item dt {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .checklist-item dd {
        margin-left: 0;
      }

      button,
      input,
      textarea,
      select,
      input[type="submit"] {
        font: inherit;
      }

      button,
      input[type="submit"] {
        appearance: none;
        -webkit-appearance: none;
        border: 0;
        padding: 12px 16px;
        cursor: pointer;
      }

      input,
      textarea,
      select {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--line);
        background: #fff;
      }

      .primary-button,
      .secondary-button,
      button {
        min-width: 148px;
      }

      .primary-button {
        background: var(--accent);
        color: white;
      }

      .secondary-button {
        background: var(--surface-strong);
        color: var(--text);
      }

      form.button_to {
        margin: 0;
      }

      .primary-link,
      .secondary-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 148px;
        padding: 12px 16px;
        text-decoration: none;
      }

      .primary-link {
        background: var(--accent);
        color: white;
      }

      .secondary-link {
        background: var(--surface-strong);
        color: var(--text);
      }

      .admin-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .admin-panel {
        display: grid;
        gap: 16px;
        margin-top: 16px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }

      .form-grid__full {
        grid-column: 1 / -1;
      }

      .csv-form {
        display: grid;
        gap: 10px;
      }

      .app-footer {
        margin-top: 32px;
        padding-top: 16px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.9rem;
      }

      .app-footer p {
        margin-bottom: 8px;
      }

      @media (max-width: 700px) {
        .page-header,
        .checklist-card__header,
        .checklist-item {
          grid-template-columns: 1fr;
          display: grid;
        }

        .page-header {
          align-items: stretch;
        }

        .primary-button,
        .secondary-button,
        .primary-link,
        .secondary-link,
        button {
          width: 100%;
        }
      }
    </style>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        function updateChecklistPercentage(checklistCard) {
          if (!checklistCard) return;

          var percentageNode = checklistCard.querySelector("[data-role='completion-percentage']");
          if (!percentageNode) return;

          var items = Array.prototype.slice.call(checklistCard.querySelectorAll("[data-checklist-item-id]"));
          var totalItems = items.length;
          var maxTargetOffset = items.reduce(function(maxValue, item) {
            var offset = parseInt(item.dataset.targetOffsetMinutes || "0", 10);
            return Math.max(maxValue, Number.isNaN(offset) ? 0 : offset);
          }, 0);

          var percentage;
          if (maxTargetOffset > 0) {
            var completedTargetOffset = items.reduce(function(maxValue, item) {
              if (!item.classList.contains("checklist-item--complete")) return maxValue;

              var offset = parseInt(item.dataset.targetOffsetMinutes || "0", 10);
              return Math.max(maxValue, Number.isNaN(offset) ? 0 : offset);
            }, 0);

            percentage = Math.round((completedTargetOffset / maxTargetOffset) * 100);
          } else {
            var completedItems = checklistCard.querySelectorAll(".checklist-item--complete").length;
            percentage = totalItems === 0 ? 0 : Math.round((completedItems / totalItems) * 100);
          }

          percentageNode.innerHTML = "<strong>" + percentage + "% complete</strong>";
        }

        document.querySelectorAll("form[data-remote-reset]").forEach(function(form) {
          form.addEventListener("submit", function(event) {
            event.preventDefault();

            var checklistCard = form.closest("[data-checklist-id]");
            var button = form.querySelector("button, input[type='submit']");
            if (!checklistCard || !button) return;

            button.disabled = true;

            fetch(form.action, {
              method: "POST",
              headers: {
                "Accept": "application/json"
              },
              body: new FormData(form),
              credentials: "same-origin"
            }).then(function(response) {
              return response.json().then(function(payload) {
                return { ok: response.ok, payload: payload };
              });
            }).then(function(result) {
              if (!result.ok) {
                throw new Error(result.payload.error || "Checklist reset failed.");
              }

              checklistCard.querySelectorAll("[data-checklist-item-id]").forEach(function(item) {
                item.classList.remove("checklist-item--complete");

                var actualNode = item.querySelector("[data-role='actual-time']");
                var deviationNode = item.querySelector("[data-role='deviation']");
                var completionForm = item.querySelector("form[data-remote-completion]");
                var completionButton = completionForm ? completionForm.querySelector("button, input[type='submit']") : null;
                var completedField = completionForm ? completionForm.querySelector("input[name='completed']") : null;

                if (actualNode) actualNode.textContent = "Not set";
                if (deviationNode) deviationNode.textContent = "Pending";
                if (completedField) completedField.value = "true";

                if (completionButton) {
                  completionButton.textContent = "Complete Item";
                  completionButton.classList.remove("primary-button", "secondary-button");
                  completionButton.classList.add("primary-button");
                }
              });

              updateChecklistPercentage(checklistCard);
            }).catch(function(error) {
              window.alert(error.message);
            }).finally(function() {
              button.disabled = false;
            });
          });
        });

        document.querySelectorAll("form[data-remote-completion]").forEach(function(form) {
          form.addEventListener("submit", function(event) {
            event.preventDefault();

            var button = form.querySelector("button, input[type='submit']");
            var checklistItem = form.closest("[data-checklist-item-id]");
            var timezoneField = form.querySelector("input[name='timezone_offset_minutes']");
            if (!button || !checklistItem) return;

            if (timezoneField) timezoneField.value = String(new Date().getTimezoneOffset());
            button.disabled = true;

            fetch(form.action, {
              method: "POST",
              headers: {
                "Accept": "application/json"
              },
              body: new FormData(form),
              credentials: "same-origin"
            }).then(function(response) {
              return response.json().then(function(payload) {
                return { ok: response.ok, payload: payload };
              });
            }).then(function(result) {
              if (!result.ok) {
                throw new Error(result.payload.error || "Checklist item update failed.");
              }

              checklistItem.classList.toggle("checklist-item--complete", result.payload.completed);

              var actualNode = checklistItem.querySelector("[data-role='actual-time']");
              var deviationNode = checklistItem.querySelector("[data-role='deviation']");
              var completedField = form.querySelector("input[name='completed']");

              if (actualNode) actualNode.innerHTML = result.payload.actual_html;
              if (deviationNode) deviationNode.textContent = result.payload.deviation_text;
              if (completedField) completedField.value = result.payload.next_completed_value;

              button.textContent = result.payload.button_label;
              button.classList.remove("primary-button", "secondary-button");
              button.classList.add(result.payload.button_class);
              updateChecklistPercentage(checklistItem.closest("[data-checklist-id]"));
            }).catch(function(error) {
              window.alert(error.message);
            }).finally(function() {
              button.disabled = false;
            });
          });
        });

        document.querySelectorAll("[data-local-datetime]").forEach(function(node) {
          var isoValue = node.dataset.localDatetime;
          if (!isoValue) return;

          var parsed = new Date(isoValue);
          if (Number.isNaN(parsed.getTime())) return;

          var month = String(parsed.getMonth() + 1).padStart(2, "0");
          var day = String(parsed.getDate()).padStart(2, "0");
          var year = String(parsed.getFullYear()).slice(-2);
          var rawHours = parsed.getHours();
          var meridiem = rawHours >= 12 ? "PM" : "AM";
          var hour12 = rawHours % 12;
          if (hour12 === 0) hour12 = 12;
          var hours = String(hour12).padStart(2, "0");
          var minutes = String(parsed.getMinutes()).padStart(2, "0");
          var timezoneParts = new Intl.DateTimeFormat(undefined, {
            timeZoneName: "short"
          }).formatToParts(parsed);
          var timezonePart = timezoneParts.find(function(part) { return part.type === "timeZoneName"; });
          var timezone = timezonePart ? timezonePart.value : "";
          var format = node.dataset.localFormat || "datetime";

          if (format === "time") {
            node.textContent = [hours + ":" + minutes, meridiem, timezone].filter(Boolean).join(" ");
            return;
          }

          node.textContent = [month + "/" + day + "/" + year, hours + ":" + minutes, meridiem, timezone].filter(Boolean).join(" ");
        });
      });
    </script>
  </head>
  <body>
    <main>
      <% flash.each do |type, message| %>
        <p class="flash"><%= "#{type.to_s.humanize}: #{message}" %></p>
      <% end %>

      <%= yield %>

      <footer class="app-footer">
        <p><strong><%= application_name %></strong></p>
        <p><%= footer_metadata.join(" | ") %></p>
      </footer>
    </main>
  </body>
</html>
