<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Checkit</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <style>
      :root {
        color-scheme: light;
        --bg: #f4f0e8;
        --surface: #fffaf1;
        --surface-strong: #f0e6d6;
        --text: #1f1a17;
        --muted: #665e58;
        --line: #d8c9b3;
        --accent: #185c52;
        --accent-strong: #103f39;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        background:
          radial-gradient(circle at top, rgba(24, 92, 82, 0.08), transparent 28%),
          linear-gradient(180deg, #f9f5ee 0%, var(--bg) 100%);
        color: var(--text);
      }

      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 24px 16px 48px;
      }

      p, h1, h2, h3, ul, dl {
        margin-top: 0;
      }

      .flash {
        margin-bottom: 16px;
        padding: 12px 14px;
        border: 1px solid var(--line);
        background: var(--surface);
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 24px;
      }

      .eyebrow {
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.75rem;
        color: var(--muted);
      }

      .checklists {
        display: grid;
        gap: 18px;
      }

      .checklist-card,
      .empty-state {
        padding: 20px;
        border: 1px solid var(--line);
        background: var(--surface);
        box-shadow: 0 14px 30px rgba(31, 26, 23, 0.06);
      }

      .checklist-card__header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        margin-bottom: 18px;
      }

      .checklist-card__notes {
        max-width: 320px;
        color: var(--muted);
      }

      .checklist-items {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 12px;
      }

      .checklist-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        padding: 16px;
        border: 1px solid var(--line);
        background: #fff;
      }

      .checklist-item--complete {
        background: #f1f8f5;
      }

      .checklist-item dl {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 10px;
        margin-bottom: 0;
      }

      .checklist-item dt {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .checklist-item dd {
        margin-left: 0;
      }

      button,
      input,
      textarea,
      select,
      input[type="submit"] {
        font: inherit;
      }

      button,
      input[type="submit"] {
        border: 0;
        padding: 12px 16px;
        cursor: pointer;
      }

      input,
      textarea,
      select {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--line);
        background: #fff;
      }

      .primary-button,
      .secondary-button,
      button {
        min-width: 148px;
      }

      .primary-button {
        background: var(--accent);
        color: white;
      }

      .secondary-button {
        background: var(--surface-strong);
        color: var(--text);
      }

      form.button_to {
        margin: 0;
      }

      .primary-link,
      .secondary-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 148px;
        padding: 12px 16px;
        text-decoration: none;
      }

      .primary-link {
        background: var(--accent);
        color: white;
      }

      .secondary-link {
        background: var(--surface-strong);
        color: var(--text);
      }

      .admin-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .admin-panel {
        display: grid;
        gap: 16px;
        margin-top: 16px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }

      .form-grid__full {
        grid-column: 1 / -1;
      }

      .csv-form {
        display: grid;
        gap: 10px;
      }

      @media (max-width: 700px) {
        .page-header,
        .checklist-card__header,
        .checklist-item {
          grid-template-columns: 1fr;
          display: grid;
        }

        .page-header {
          align-items: stretch;
        }

        .primary-button,
        .secondary-button,
        .primary-link,
        .secondary-link,
        button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <% flash.each do |type, message| %>
        <p class="flash"><%= "#{type.to_s.humanize}: #{message}" %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
