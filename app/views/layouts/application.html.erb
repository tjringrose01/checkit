<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Checkit</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <style>
      :root {
        --primary: #4a8feb;
        --primary-light: #6ba5f2;
        --secondary: #6ed5b7;
        --secondary-light: #8ee1c9;
        --accent: #f887b8;
        --dark: #2a3b4c;
        --text: #3a4a5c;
        --text-light: #778899;
        --light: #f5f8ff;
        --shadow: rgba(42, 59, 76, 0.1);
        --glass: rgba(255, 255, 255, 0.9);
        --glass-dark: rgba(42, 59, 76, 0.03);
        --line: rgba(74, 143, 235, 0.12);
      }

      @font-face {
        font-family: "Inter";
        font-style: normal;
        font-weight: 400;
        src: url("https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiA.woff2") format("woff2");
      }

      @font-face {
        font-family: "Inter";
        font-style: normal;
        font-weight: 600;
        src: url("https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuGKYAZ9hiA.woff2") format("woff2");
      }

      @font-face {
        font-family: "Inter";
        font-style: normal;
        font-weight: 700;
        src: url("https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuFuYAZ9hiA.woff2") format("woff2");
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: linear-gradient(135deg, #f5f8ff 0%, #eef5ff 100%);
        color: var(--text);
        font-family: "Inter", sans-serif;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        overflow: hidden;
      }

      a {
        color: var(--primary);
      }

      .app-container {
        width: 100%;
        max-width: 1160px;
        height: min(920px, calc(100vh - 48px));
        background: var(--light);
        border-radius: 24px;
        box-shadow: 0 20px 60px var(--shadow);
        overflow: hidden;
        display: grid;
        grid-template-rows: auto 1fr;
        position: relative;
      }

      .floating-bubble {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.2));
        filter: blur(1px);
        animation: float 8s infinite ease-in-out;
        z-index: 0;
      }

      .floating-bubble--one {
        width: 120px;
        height: 120px;
        top: 72px;
        left: -32px;
      }

      .floating-bubble--two {
        width: 180px;
        height: 180px;
        right: -56px;
        bottom: 120px;
        animation-delay: 1.5s;
      }

      .nav {
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        background: var(--glass);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        position: relative;
        z-index: 10;
      }

      .logo {
        font-weight: 700;
        font-size: 24px;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .logo-icon {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        border-radius: 8px;
        color: white;
      }

      .nav-links {
        display: flex;
        gap: 24px;
        align-items: center;
      }

      .nav-link {
        text-decoration: none;
        color: var(--text-light);
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
        position: relative;
      }

      .nav-link:hover,
      .nav-link.active {
        color: var(--primary);
      }

      .nav-link.active::after {
        content: "";
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
        border-radius: 10px;
      }

      .user {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .user-meta {
        text-align: right;
      }

      .user-meta strong {
        display: block;
        font-size: 14px;
        color: var(--dark);
      }

      .user-meta span {
        font-size: 12px;
        color: var(--text-light);
      }

      .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6a6cff 0%, #cb52f7 100%);
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: 600;
        font-size: 14px;
      }

      .main {
        padding: 30px;
        overflow-y: auto;
        position: relative;
        z-index: 1;
      }

      .main::-webkit-scrollbar {
        width: 6px;
      }

      .main::-webkit-scrollbar-track {
        background: transparent;
      }

      .main::-webkit-scrollbar-thumb {
        background: var(--primary-light);
        border-radius: 10px;
      }

      .content-stack {
        display: grid;
        gap: 24px;
      }

      p, h1, h2, h3, ul, dl {
        margin-top: 0;
      }

      h1 {
        font-size: 30px;
        font-weight: 700;
        color: var(--dark);
      }

      h2 {
        font-size: 20px;
        font-weight: 700;
        color: var(--dark);
      }

      h3 {
        font-size: 16px;
        font-weight: 600;
        color: var(--dark);
      }

      .flash-group {
        display: grid;
        gap: 12px;
      }

      .flash {
        padding: 14px 16px;
        border-radius: 14px;
        background: white;
        border: 1px solid var(--line);
        box-shadow: 0 4px 20px var(--shadow);
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        align-items: flex-start;
      }

      .eyebrow {
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.75rem;
        color: var(--text-light);
      }

      .checklists {
        display: grid;
        gap: 20px;
      }

      .checklist-card,
      .empty-state {
        padding: 24px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 20px var(--shadow);
        border: 1px solid rgba(74, 143, 235, 0.06);
      }

      .checklist-card__header {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: flex-start;
        margin-bottom: 20px;
      }

      .checklist-card__notes {
        max-width: 360px;
        color: var(--text-light);
      }

      .checklist-items {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 16px;
      }

      .checklist-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 20px;
        padding: 20px;
        border-radius: 16px;
        border: 1px solid rgba(74, 143, 235, 0.08);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 248, 255, 0.92));
      }

      .checklist-item--complete {
        background: linear-gradient(180deg, rgba(142, 225, 201, 0.24), rgba(255, 255, 255, 0.98));
      }

      .checklist-item__text > :last-child {
        margin-bottom: 0;
      }

      .checklist-item__meta {
        margin-top: 12px;
      }

      .checklist-item__meta p:last-child {
        margin-bottom: 0;
      }

      .checklist-item dl {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 14px;
        margin-top: 16px;
        margin-bottom: 0;
      }

      .checklist-item dt {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-light);
        margin-bottom: 6px;
      }

      .checklist-item dd {
        margin-left: 0;
        font-weight: 600;
        color: var(--dark);
      }

      button,
      input,
      textarea,
      select,
      input[type="submit"] {
        font: inherit;
      }

      button,
      input[type="submit"] {
        appearance: none;
        -webkit-appearance: none;
        border: none;
        padding: 10px 16px;
        cursor: pointer;
        border-radius: 10px;
        transition: all 0.2s ease;
      }

      input,
      textarea,
      select {
        width: 100%;
        padding: 12px;
        border: 1px solid rgba(74, 143, 235, 0.16);
        background: rgba(255, 255, 255, 0.94);
        border-radius: 12px;
        color: var(--dark);
      }

      input:focus,
      textarea:focus,
      select:focus {
        outline: 2px solid rgba(74, 143, 235, 0.2);
        border-color: var(--primary-light);
      }

      .primary-button,
      .secondary-button,
      button,
      .primary-link,
      .secondary-link {
        min-width: 148px;
        justify-content: center;
      }

      .primary-button {
        background: var(--primary);
        color: white;
      }

      .primary-button:hover,
      .primary-link:hover {
        background: var(--primary-light);
        transform: translateY(-2px);
      }

      .secondary-button {
        background: transparent;
        border: 1px solid var(--primary);
        color: var(--primary);
      }

      .secondary-button:hover,
      .secondary-link:hover {
        background: rgba(74, 143, 235, 0.1);
        transform: translateY(-2px);
      }

      form.button_to {
        margin: 0;
      }

      .primary-link,
      .secondary-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 16px;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.2s ease;
      }

      .primary-link {
        background: var(--primary);
        color: white;
      }

      .secondary-link {
        background: transparent;
        border: 1px solid var(--primary);
        color: var(--primary);
      }

      .admin-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
      }

      .admin-panel {
        display: grid;
        gap: 16px;
        margin-top: 20px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }

      .form-grid__full {
        grid-column: 1 / -1;
      }

      .csv-form {
        display: grid;
        gap: 10px;
      }

      section > p,
      article p,
      label,
      .empty-state p {
        color: var(--text-light);
        line-height: 1.55;
      }

      section form {
        display: grid;
        gap: 16px;
      }

      section form > div {
        display: grid;
        gap: 8px;
      }

      .empty-state {
        text-align: center;
      }

      .app-footer {
        margin-top: 8px;
        padding-top: 16px;
        border-top: 1px solid rgba(74, 143, 235, 0.12);
        color: var(--text-light);
        font-size: 0.9rem;
      }

      .app-footer p {
        margin-bottom: 8px;
      }

      @keyframes float {
        0%, 100% {
          transform: translateY(0) scale(1);
        }
        50% {
          transform: translateY(-15px) scale(1.05);
        }
      }

      @media (max-width: 700px) {
        body {
          padding: 0;
        }

        .app-container {
          height: 100vh;
          max-width: 100%;
          border-radius: 0;
        }

        .nav {
          padding: 16px;
        }

        .main {
          padding: 20px;
        }

        .page-header,
        .checklist-card__header,
        .checklist-item {
          grid-template-columns: 1fr;
          display: grid;
        }

        .page-header {
          align-items: stretch;
        }

        .primary-button,
        .secondary-button,
        .primary-link,
        .secondary-link,
        button {
          width: 100%;
        }

        .nav-links {
          display: none;
        }

        .user-meta {
          display: none;
        }
      }
    </style>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        function updateChecklistPercentage(checklistCard) {
          if (!checklistCard) return;

          var percentageNode = checklistCard.querySelector("[data-role='completion-percentage']");
          if (!percentageNode) return;

          var items = Array.prototype.slice.call(checklistCard.querySelectorAll("[data-checklist-item-id]"));
          var totalItems = items.length;
          var maxTargetOffset = items.reduce(function(maxValue, item) {
            var offset = parseInt(item.dataset.targetOffsetMinutes || "0", 10);
            return Math.max(maxValue, Number.isNaN(offset) ? 0 : offset);
          }, 0);

          var percentage;
          if (maxTargetOffset > 0) {
            var completedTargetOffset = items.reduce(function(maxValue, item) {
              if (!item.classList.contains("checklist-item--complete")) return maxValue;

              var offset = parseInt(item.dataset.targetOffsetMinutes || "0", 10);
              return Math.max(maxValue, Number.isNaN(offset) ? 0 : offset);
            }, 0);

            percentage = Math.round((completedTargetOffset / maxTargetOffset) * 100);
          } else {
            var completedItems = checklistCard.querySelectorAll(".checklist-item--complete").length;
            percentage = totalItems === 0 ? 0 : Math.round((completedItems / totalItems) * 100);
          }

          percentageNode.innerHTML = "<strong>" + percentage + "% complete</strong>";
        }

        document.querySelectorAll("form[data-remote-reset]").forEach(function(form) {
          form.addEventListener("submit", function(event) {
            event.preventDefault();

            var checklistCard = form.closest("[data-checklist-id]");
            var button = form.querySelector("button, input[type='submit']");
            if (!checklistCard || !button) return;

            button.disabled = true;

            fetch(form.action, {
              method: "POST",
              headers: {
                "Accept": "application/json"
              },
              body: new FormData(form),
              credentials: "same-origin"
            }).then(function(response) {
              return response.json().then(function(payload) {
                return { ok: response.ok, payload: payload };
              });
            }).then(function(result) {
              if (!result.ok) {
                throw new Error(result.payload.error || "Checklist reset failed.");
              }

              checklistCard.querySelectorAll("[data-checklist-item-id]").forEach(function(item) {
                item.classList.remove("checklist-item--complete");

                var actualNode = item.querySelector("[data-role='actual-time']");
                var deviationNode = item.querySelector("[data-role='deviation']");
                var completionForm = item.querySelector("form[data-remote-completion]");
                var completionButton = completionForm ? completionForm.querySelector("button, input[type='submit']") : null;
                var completedField = completionForm ? completionForm.querySelector("input[name='completed']") : null;

                if (actualNode) actualNode.textContent = "Not set";
                if (deviationNode) deviationNode.textContent = "Pending";
                if (completedField) completedField.value = "true";

                if (completionButton) {
                  completionButton.textContent = "Complete Item";
                  completionButton.classList.remove("primary-button", "secondary-button");
                  completionButton.classList.add("primary-button");
                }
              });

              updateChecklistPercentage(checklistCard);
            }).catch(function(error) {
              window.alert(error.message);
            }).finally(function() {
              button.disabled = false;
            });
          });
        });

        document.querySelectorAll("form[data-remote-completion]").forEach(function(form) {
          form.addEventListener("submit", function(event) {
            event.preventDefault();

            var button = form.querySelector("button, input[type='submit']");
            var checklistItem = form.closest("[data-checklist-item-id]");
            var timezoneField = form.querySelector("input[name='timezone_offset_minutes']");
            if (!button || !checklistItem) return;

            if (timezoneField) timezoneField.value = String(new Date().getTimezoneOffset());
            button.disabled = true;

            fetch(form.action, {
              method: "POST",
              headers: {
                "Accept": "application/json"
              },
              body: new FormData(form),
              credentials: "same-origin"
            }).then(function(response) {
              return response.json().then(function(payload) {
                return { ok: response.ok, payload: payload };
              });
            }).then(function(result) {
              if (!result.ok) {
                throw new Error(result.payload.error || "Checklist item update failed.");
              }

              checklistItem.classList.toggle("checklist-item--complete", result.payload.completed);

              var actualNode = checklistItem.querySelector("[data-role='actual-time']");
              var deviationNode = checklistItem.querySelector("[data-role='deviation']");
              var completedField = form.querySelector("input[name='completed']");

              if (actualNode) actualNode.innerHTML = result.payload.actual_html;
              if (deviationNode) deviationNode.textContent = result.payload.deviation_text;
              if (completedField) completedField.value = result.payload.next_completed_value;

              button.textContent = result.payload.button_label;
              button.classList.remove("primary-button", "secondary-button");
              button.classList.add(result.payload.button_class);
              updateChecklistPercentage(checklistItem.closest("[data-checklist-id]"));
            }).catch(function(error) {
              window.alert(error.message);
            }).finally(function() {
              button.disabled = false;
            });
          });
        });

        document.querySelectorAll("[data-local-datetime]").forEach(function(node) {
          var isoValue = node.dataset.localDatetime;
          if (!isoValue) return;

          var parsed = new Date(isoValue);
          if (Number.isNaN(parsed.getTime())) return;

          var month = String(parsed.getMonth() + 1).padStart(2, "0");
          var day = String(parsed.getDate()).padStart(2, "0");
          var year = String(parsed.getFullYear()).slice(-2);
          var rawHours = parsed.getHours();
          var meridiem = rawHours >= 12 ? "PM" : "AM";
          var hour12 = rawHours % 12;
          if (hour12 === 0) hour12 = 12;
          var hours = String(hour12).padStart(2, "0");
          var minutes = String(parsed.getMinutes()).padStart(2, "0");
          var timezoneParts = new Intl.DateTimeFormat(undefined, {
            timeZoneName: "short"
          }).formatToParts(parsed);
          var timezonePart = timezoneParts.find(function(part) { return part.type === "timeZoneName"; });
          var timezone = timezonePart ? timezonePart.value : "";
          var format = node.dataset.localFormat || "datetime";

          if (format === "time") {
            node.textContent = [hours + ":" + minutes, meridiem, timezone].filter(Boolean).join(" ");
            return;
          }

          node.textContent = [month + "/" + day + "/" + year, hours + ":" + minutes, meridiem, timezone].filter(Boolean).join(" ");
        });
      });
    </script>
  </head>
  <body>
    <div class="app-container">
      <div class="floating-bubble floating-bubble--one"></div>
      <div class="floating-bubble floating-bubble--two"></div>

      <nav class="nav">
        <div class="logo">
          <div class="logo-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M16 4C16 2.89543 15.1046 2 14 2H10C8.89543 2 8 2.89543 8 4V6H16V4Z" fill="currentColor"/>
              <path d="M18.5 6H5.5C4.11929 6 3 7.11929 3 8.5V19C3 20.6569 4.34315 22 6 22H18C19.6569 22 21 20.6569 21 19V8.5C21 7.11929 19.8807 6 18.5 6Z" fill="currentColor"/>
              <path d="M10.5 11.5C10.5 10.6716 11.1716 10 12 10C12.8284 10 13.5 10.6716 13.5 11.5V13.5H15.5C16.3284 13.5 17 14.1716 17 15C17 15.8284 16.3284 16.5 15.5 16.5H13.5V18.5C13.5 19.3284 12.8284 20 12 20C11.1716 20 10.5 19.3284 10.5 18.5V16.5H8.5C7.67157 16.5 7 15.8284 7 15C7 14.1716 7.67157 13.5 8.5 13.5H10.5V11.5Z" fill="white"/>
            </svg>
          </div>
          <span><%= application_name %></span>
        </div>

        <div class="nav-links">
          <%= link_to "Dashboard", authenticated? ? root_path : new_session_path, class: "nav-link active" %>
          <% if authenticated? && current_user.admin? %>
            <%= link_to "Admin", admin_root_path, class: "nav-link" %>
            <%= link_to "Users", admin_users_path, class: "nav-link" %>
          <% elsif authenticated? %>
            <%= link_to "Checklists", root_path, class: "nav-link" %>
          <% else %>
            <%= link_to "Sign In", new_session_path, class: "nav-link" %>
            <%= link_to "Register", new_registration_path, class: "nav-link" %>
          <% end %>
        </div>

        <div class="user">
          <% if authenticated? %>
            <div class="user-meta">
              <strong><%= current_user.user_id %></strong>
              <span><%= current_user.role.titleize %></span>
            </div>
            <div class="user-avatar"><%= current_user.user_id.first(2).upcase %></div>
          <% else %>
            <div class="user-meta">
              <strong>Guest</strong>
              <span>Public Access</span>
            </div>
            <div class="user-avatar">GU</div>
          <% end %>
        </div>
      </nav>

      <main class="main">
        <div class="content-stack">
          <% if flash.any? %>
            <div class="flash-group">
              <% flash.each do |type, message| %>
                <p class="flash"><%= "#{type.to_s.humanize}: #{message}" %></p>
              <% end %>
            </div>
          <% end %>

          <%= yield %>

          <footer class="app-footer">
            <p><strong><%= application_name %></strong></p>
            <p><%= footer_metadata.join(" | ") %></p>
          </footer>
        </div>
      </main>
    </div>
  </body>
</html>
