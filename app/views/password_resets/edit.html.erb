<section>
  <h1>Set New Password</h1>
  <p>Choose a new password for your account.</p>

  <%= form_with model: @user, url: password_reset_path, method: :patch do |form| %>
    <div>
      <%= form.label :password, "New password" %>
      <%= form.password_field :password, required: true, minlength: 12, autocomplete: "new-password" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm new password" %>
      <%= form.password_field :password_confirmation, required: true, minlength: 12, autocomplete: "new-password" %>
    </div>

    <%= form.submit "Update password", class: "primary-button" %>
  <% end %>
</section>
